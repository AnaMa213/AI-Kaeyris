APP_VERSION=0.0.1

# API keys — see ADR 0003.
# Format: name1:argon2_hash1;name2:argon2_hash2  (semicolon separator)
# Generate a new entry with: python scripts/generate_api_key.py <name>
# Empty by default → all authenticated routes reject every request.
#
# IMPORTANT: wrap the value in SINGLE QUOTES. Argon2 hashes contain '$'
# characters that python-dotenv would otherwise treat as variable
# references (the hash would be silently mangled and auth would always
# return 401 "Invalid API key").
#
# Example (do not use these values — generate your own):
# API_KEYS='laptop:$argon2id$v=19$m=65536,t=3,p=4$abc$def'
API_KEYS=

# Web auth (front). No default account or password exists: on a fresh DB,
# the front must call GET /services/jdr/auth/setup/status then
# POST /services/jdr/auth/setup to create the first GM.
# Use a comma-separated allowlist when the browser origin differs from the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000
SESSION_COOKIE_NAME=session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
WEB_SESSION_TTL_SECONDS=28800

# Async jobs and rate limiting — see ADR 0004.
# Inside Docker Compose this is overridden to redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_WINDOW_SECONDS=60

# LLM adapter — see ADR 0005.
# Supported providers (all OpenAI-compatible): deepinfra, openai, groq,
# ollama, vllm, together, mock.
LLM_PROVIDER=deepinfra
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS_DEFAULT=1000

# Local on RTX 4090 + Ollama — uncomment and start `ollama serve` first:
# In Docker Compose, the worker runs in a container: do not use localhost
# here unless the LLM server runs in that same container. Use the host gateway
# below, or a Compose service name such as http://ollama:11434/v1.
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b-instruct-q4_K_M
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama-noop

# Persistence (Jalon 5) — see ADR 0006.
# Async driver is encoded in the URL: sqlite+aiosqlite://, postgresql+asyncpg://
# Dev default = SQLite file. Prod (docker-compose.prod.yml) overrides this
# to postgresql+asyncpg://<user>:<pwd>@postgres:5432/<db> using the
# POSTGRES_* variables below.
DATABASE_URL=sqlite+aiosqlite:///./data/kaeyris.db

# Production Postgres (Jalon 8) — only consumed by docker-compose.prod.yml
# to seed the postgres service AND to build the DATABASE_URL above.
# Keep the password strong (random ≥ 32 chars) — see CLAUDE.md §2.6.
POSTGRES_USER=kaeyris
POSTGRES_PASSWORD=change-me-in-real-deploy
POSTGRES_DB=kaeyris

# Production image (Jalon 8). Default points at the GHCR release Watchtower
# polls. Override locally with `KAEYRIS_IMAGE=ai-kaeyris:local` after a
# `docker compose -f docker-compose.prod.yml build`.
KAEYRIS_IMAGE=ghcr.io/anama213/ai-kaeyris:latest

# Caddy reverse proxy basic auth (Jalon 8) — protects GET /metrics so
# Prometheus is the only scraper. Generate the bcrypt hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext '<pwd>'
# Wrap in SINGLE QUOTES because the hash contains '$'.
CADDY_METRICS_HASH='$2a$14$REPLACE_ME_WITH_REAL_HASH'

# Grafana admin (Jalon 8). Set a strong password before the first
# `docker compose -f docker-compose.prod.yml up` — Grafana persists the
# initial hash in its DB and ignores subsequent env changes.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# JDR service — local data directory (audios + SQLite DB live here in dev).
KAEYRIS_DATA_DIR=./data
# BD-9 server-side audio reduce. Raw upload ceiling before the worker
# prepares a smaller transcription-ready audio file. Default = 500 MiB.
KAEYRIS_AUDIO_MAX_UPLOAD_BYTES=524288000

# Transcription adapter (Jalon 5) — see ADR 0006 §2.
# Providers: cloud (OpenAI/Groq/DeepInfra/Together compatible) or local
# (self-hosted faster-whisper + pyannote on a LAN GPU host).
# 'mock' is reserved for tests.
TRANSCRIPTION_PROVIDER=cloud
TRANSCRIPTION_BASE_URL=
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_MODEL=whisper-large-v3
TRANSCRIPTION_TIMEOUT_SECONDS=1800
TRANSCRIPTION_LANGUAGE_HINT=fr
# Splits the upload into pieces of this many seconds before sending each
# one to Whisper. Caps the blast radius of repetition-loop hallucinations
# (a stuck phrase can only contaminate one chunk). Set to 0 to disable.
TRANSCRIPTION_CHUNK_DURATION_SECONDS=30

# Local GPU host (RTX 4090 + faster-whisper + pyannote) — uncomment when ready:
# TRANSCRIPTION_PROVIDER=local
# TRANSCRIPTION_BASE_URL=http://gpu-host.lan:8001/v1
# TRANSCRIPTION_API_KEY=local-noop

# Sous-jalon 5.5 — mode `non_diarised` (002-non-diarised-mode).
# Taille maximale (caractères) d'un chunk de transcription stocké dans
# jdr_chunks pour une session non_diarised. Affecte le chunking texte
# au démontage post-transcription. Doit être > 0.
KAEYRIS_CHUNK_MAX_CHARS=30000

# Observabilité (Jalon 6) — see ADR 0008.
# Logs: console (dev humain) ou json (prod 1 ligne/log).
LOG_FORMAT=console
LOG_LEVEL=INFO

# OpenTelemetry tracing — opt-in. Désactivé par défaut.
# Quand activé, FastAPI / SQLAlchemy / httpx sont auto-instrumentés.
OTEL_ENABLED=false
OTEL_EXPORTER=console
# OTEL_EXPORTER=otlp   # uncomment quand un collector tourne en sidecar
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=ai-kaeyris
