# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.venv/
venv/
env/

# Environment
.env
.env.*
!.env.example

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log

# Claude Code (worktrees temporaires, jamais à commiter)
.claude/worktrees/

# Spec Kit (cache et fichiers temporaires d'agent uniquement ;
# .specify/ et .claude/skills/ restent trackés volontairement pour la pédagogie)
.specify/cache/
.specify/.tmp/

# Local data (Jalon 5) — SQLite DB, audios en cours de transcription, etc.
# Le dossier lui-même est tracké via data/.gitkeep mais son contenu non.
data/*
!data/.gitkeep
!data/audios/
data/audios/*
!data/audios/.gitkeep
